{
  "base_model": "Qwen/Qwen2.5-7B-Instruct",
  "lora": {
    "r": 16,
    "lora_alpha": 32,
    "lora_dropout": 0.05,
    "target_modules": [
      "q_proj",
      "k_proj",
      "v_proj",
      "o_proj",
      "gate_proj",
      "up_proj",
      "down_proj"
    ],
    "bias": "none",
    "task_type": "CAUSAL_LM"
  },
  "qlora": {
    "load_in_4bit": true,
    "bnb_4bit_quant_type": "nf4",
    "bnb_4bit_use_double_quant": true,
    "bnb_4bit_compute_dtype": "bfloat16"
  },
  "training": {
    "num_train_epochs": 3,
    "per_device_train_batch_size": 1,
    "gradient_accumulation_steps": 8,
    "effective_batch_size": 8,
    "learning_rate": 0.0002,
    "warmup_ratio": 0.03,
    "lr_scheduler_type": "cosine",
    "max_length": 1024,
    "dataset_text_field": "text",
    "logging_steps": 10,
    "save_strategy": "epoch",
    "fp16": false,
    "bf16": true,
    "optim": "paged_adamw_8bit",
    "report_to": "none",
    "gradient_checkpointing": true,
    "dataloader_num_workers": 0
  },
  "adapter_output_dir": "C:\\Users\\USER\\OneDrive\\Desktop\\CENG493_Project\\CENG493_Project\\models\\qwen25_lora"
}